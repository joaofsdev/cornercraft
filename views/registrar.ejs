<%- include('partials/header') %>
<div class="flex justify-center items-center h-screen bg-green-50">
    <div class="bg-white p-6 rounded-lg shadow-lg w-full max-w-md">
        <h2 class="text-xl font-bold text-green-800 mb-4">Criar Conta</h2>
        <form action="/auth/registrar" method="POST">
            <div class="mb-4">
                <label class="block text-gray-700">Nome completo</label>
                <input type="text" name="nome" class="w-full p-2 border rounded" placeholder="Seu nome completo" required>
            </div>
            <div class="mb-4">
                <label class="block text-gray-700">Email</label>
                <input type="email" name="email" class="w-full p-2 border rounded" placeholder="seu.email@exemplo.com" required>
            </div>
            <div class="mb-4">
                <label class="block text-gray-700">Senha</label>
                <input type="password" name="senha" class="w-full p-2 border rounded" placeholder="Crie uma senha segura" required>
            </div>
            <% if (erro) { %>
                <p class="text-red-600 mb-4"><%= erro %></p>
            <% } %>
            <button type="submit" class="w-full bg-green-600 text-white p-2 rounded hover:bg-green-700 transition">Criar Conta</button>
        </form>
        <p class="text-center mt-4">
            Já tem uma conta? <a href="/auth/login" class="text-green-600 hover:text-green-700 hover:underline">Faça login</a>
        </p>
        <p class="text-center text-gray-600 mt-4">
            Para facilitar os testes, você pode usar:<br>
            Email: admin@cornercraft.com<br>
            Senha: admin123
        </p>
    </div>
</div>